# MAZU 媽祖娘娘語音通話 — 環境變數
# 使用方式：複製此檔為 .env，並填入下方實際數值（不要提交 .env 到 Git）

# 服務埠號（選填，預設 3000）
PORT=3000

# OpenAI API Key（必填，STT + LLM）
OPENAI_API_KEY=your-openai-api-key

# MiniMax API Key（必填，TTS）
MINIMAX_API_KEY=your-minimax-api-key

# MiniMax Group ID（必填）
MINIMAX_GROUP_ID=your-minimax-group-id

# MiniMax Voice ID（選填，預設使用內建 voice）
MINIMAX_VOICE_ID=your-minimax-voice-id

# Google OAuth Client ID（選填，啟用 Google 登入）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# 登入帳密（選填）
AUTH_USERNAME=WAITIN
AUTH_PASSWORD=1688
