# MAZU 媽祖娘娘語音通話 — 環境變數
# 使用方式：複製此檔為 .env，並填入下方實際數值（不要提交 .env 到 Git）

# 服務埠號（選填，預設 3000）
PORT=3000

# Anthropic API Key（必填，LLM 用 Claude Sonnet 4.6）
ANTHROPIC_API_KEY=your-anthropic-api-key

# MiniMax API Key（必填，TTS + STT）
MINIMAX_API_KEY=your-minimax-api-key

# MiniMax Group ID（必填）
MINIMAX_GROUP_ID=2031505416692703604

# MiniMax Voice ID（選填，預設使用內建 voice）
MINIMAX_VOICE_ID=moss_audio_d739901e-1d39-11f1-9b14-6299e7260fda

# 登入帳密（選填，預設 WAITIN / 1688）
AUTH_USERNAME=WAITIN
AUTH_PASSWORD=1688
